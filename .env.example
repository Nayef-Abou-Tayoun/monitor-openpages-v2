# OpenPages Configuration for Process Finder
# Copy this file to .env and update with your credentials

# OpenPages Server URL
OPENPAGES_BASE_URL=https://your-openpages-server.com/openpages

# Authentication Type (basic or bearer)
AUTH_TYPE=basic

# OpenPages Credentials
OPENPAGES_USERNAME=your_username_here
OPENPAGES_PASSWORD=your_password_here

# Optional: For bearer token authentication
# OPENPAGES_API_KEY=your_api_key_here
# AUTHENTICATION_URL=https://your-auth-server.com/token

# IBM Cloud Object Storage Configuration
COS_API_KEY=your_cos_api_key_here
COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:a/your_account_id:your_instance_id::
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_BUCKET_NAME=your-bucket-name

# Watson Orchestrate Configuration
WXO_API_KEY=your_watson_orchestrate_api_key_here
WXO_SKILL_ID=your_skill_id_here
WXO_AUTH_URL=https://iam.cloud.ibm.com/identity/token
WXO_ENDPOINT=https://api.us-south.assistant.watson.cloud.ibm.com

# Process Configuration
PROCESS_ID=your_process_id_here
CHECK_INTERVAL=60
